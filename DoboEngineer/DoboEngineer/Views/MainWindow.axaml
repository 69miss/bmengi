<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:DoboEngineer.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="using:DoboEngineer"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="DoboEngineer.Views.MainWindow"
        
        Icon="/Assets/avalonia-logo.ico"
        x:DataType="vm:MainWindowViewModel"
        Title="DoboEngineer">
     <!--DataContext="{Binding RelativeSource={RelativeSource Self}}"-->
    <!--<Design.DataContext> x:DataType="vm:MainWindowViewModel"
        --><!-- This only sets the DataContext for the previewer in an IDE,
             to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs) --><!--
        <vm:MainWindowViewModel/>
    </Design.DataContext>-->
    <Grid Margin="20" ColumnDefinitions="*, Auto" RowDefinitions="Auto, *">
        <StackPanel HorizontalAlignment="Left"  Orientation="Horizontal">
			
        
    <TextBlock Text="{Binding Greeting}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        <Button Click="Button_Click">外部校准盒校准</Button>
         <Button Click="Button_Click_1" IsVisible="False">校准2</Button>
            <Button Click="Button_Click_2">泵站测试</Button>
            <Button Click="Button_Click_3">泵站控制</Button>
            <Button Click="Button_Click_4">端盖开关测试</Button>
            <Button Click="Button_Click_5">命令工具</Button>
            <Button Click="Button_Click_6">泵站组</Button>

             <local:Group Height="600" Width="300"  />
            <local:Group Height="600" Width="300"  />
            <local:Group Height="600" Width="300"  />
            </StackPanel>
    </Grid>
</Window>
