<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="DoboEngineer.SPCTool"
        Title="SPCTool">
  <Grid Margin="20" ColumnDefinitions="*, Auto" RowDefinitions="Auto, *">
			<StackPanel Orientation="Horizontal" >
			<Button Click="btnBegin2_Click"  x:Name="btnBegin2" Content="开关盖循环测试"> </Button>
			<Button Click="btnBegin1_Click"  x:Name="btnBegin1" Content="停止开关盖循环测试"> </Button>
			</StackPanel>
			
			<TextBox Grid.Column="0" Grid.Row="1" x:Name="tbTxt"
					 Name="tbTxt" 
					 AcceptsReturn="True"
					 TextWrapping="Wrap"
					 IsReadOnly="False"
					 Margin="0,10,0,0"/>
			<SelectableTextBlock Grid.Column="1" Grid.Row="1" Text=""></SelectableTextBlock >
		</Grid>
</Window>
