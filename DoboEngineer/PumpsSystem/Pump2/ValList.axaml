<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:PumpsSystem.Pump2"
        x:Class="PumpsSystem.Pump2.ValList"
        x:DataType="vm:ValListVM"
        Title="参数监控" Width="800" Height="400">

    <Window.DataContext>
        <vm:ValListVM/>
    </Window.DataContext>

    <!-- 1. 定义全局样式，压缩 ListBoxItem 的默认高度和内边距 -->
    <Window.Styles>
        <Style Selector="ListBoxItem">
            <!-- 减小每一行的内边距 (左右4，上下2) -->
            <Setter Property="Padding" Value="4,2"/>
            <!-- 降低最小高度，打破 Avalonia 默认主题的宽大限制 -->
            <Setter Property="MinHeight" Value="28"/>
        </Style>
    </Window.Styles>

    <!-- 使用 Auto 和 * 布局：* 代表 ListBox 会填满剩余空间，超出部分自动滚动 -->
    <Grid RowDefinitions="Auto, *">

        <!-- 表头 (固定在顶部不随列表滚动) -->
        <Border Grid.Row="0" Background="#EEEEEE" Padding="10,8">
            <Grid ColumnDefinitions="150, 180, 100,150, *">
                <TextBlock Grid.Column="0" Text="地址" FontWeight="Bold"/>
                <TextBlock Grid.Column="1" Text="名称" FontWeight="Bold"/>
                <TextBlock Grid.Column="2" Text="值" FontWeight="Bold"/>
                <TextBlock Grid.Column="3" Text="值2" FontWeight="Bold"/>
                <TextBlock Grid.Column="4" Text="操作" FontWeight="Bold"/>
            </Grid>
        </Border>

        <!-- 列表内容 -->
        <!-- 2. ScrollViewer.VerticalScrollBarVisibility="Auto" 确保超出时显示垂直滚动条 -->
        <ListBox Grid.Row="1"
                 ItemsSource="{Binding DataItems}"
                 Margin="0"
                 BorderThickness="0"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">

            <ListBox.ItemTemplate>
                <DataTemplate>
                    <!-- 3. 将原先的 Margin="0,8" 改小为 Margin="0,2" -->
                    <Grid ColumnDefinitions="80, 150,80, 150, *" Margin="0,2">

                        <!-- 地址 -->
                        <TextBlock Grid.Column="0" Text="{Binding Address}" VerticalAlignment="Center"/>

                        <!-- 名称 -->
                        <TextBlock Grid.Column="1" Text="{Binding Name}" VerticalAlignment="Center"/>

                        <!-- 实时值 -->
                        <TextBlock Grid.Column="2"
                                   Text="{Binding Value}"
                                   Foreground="DarkOrange"
                                   FontWeight="Bold"
                                   VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="3"
                                   Text="{Binding Value,StringFormat='{}{0:B}'}"
                                   Foreground="DarkOrange"
                                   FontWeight="Bold"
                                   VerticalAlignment="Center"/>
                        <!-- 操作列 -->
                        <Grid Grid.Column="4">
                            <StackPanel Orientation="Horizontal" Spacing="8" IsVisible="{Binding CanWrite}">
                                <!-- 4. 降低 TextBox 和 Button 的内边距和高度，防止它们把当前行撑得太高 {Binding InputValue}{Binding SendUpdateCommand}-->
                                <TextBox x:Name="txtSend"
                                         Width="100"
                                         MinHeight="24"
                                         Height="24"
                                         Padding="4,2"
                                         Watermark="输入新值"
                                         VerticalAlignment="Center"
                                         VerticalContentAlignment="Center"/>

                                <Button Content="发送"
                                        Command="{Binding $parent[Window].DataContext.SendCommand}"
                                        MinHeight="24"
                                        Height="24"
                                        Padding="10,2"
                                        Cursor="Hand"
                                        VerticalAlignment="Center"
                                        VerticalContentAlignment="Center">
                                    <Button.CommandParameter>
                                        <MultiBinding>
                                            <Binding />
                                            <Binding Path="Text" ElementName="txtSend"/>
                                        </MultiBinding>
                                    </Button.CommandParameter>
                                </Button>
                            </StackPanel>

                            <TextBlock Text="[ 只读 ]"
                                       Foreground="Gray"
                                       FontStyle="Italic"
                                       VerticalAlignment="Center"
                                       IsVisible="{Binding !CanWrite}"/>
                        </Grid>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</Window>